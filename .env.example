# =============================================================================
# MercadoLibre Sync - Variables de entorno para otra marca/cuenta
# =============================================================================
# Copia este archivo a .env y reemplaza con las credenciales de la nueva cuenta.
# El sales-dashboard usa estas credenciales vía el .env de sales-dashboard
# (o carga ambos .env)
# =============================================================================

# --- Shopify ---
SHOPIFY_STORE_URL=tu-tienda.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_LOCATION_ID=12345678901

# --- MercadoLibre ---
MELI_APP_ID=123456789012345
MELI_CLIENT_SECRET=tu_client_secret_de_mercadolibre
MELI_ACCESS_TOKEN=APP_USR-xxxxx-xxxxx-xxxxxxxxxxxxxxxxxxxxxxxx-1234567890
MELI_USER_ID=1234567890
MELI_REFRESH_TOKEN=TG-xxxxxxxxxxxxxxxxxxxxxxxx-1234567890

# --- Falabella (opcional) ---
ENABLE_FALABELLA=false
FALABELLA_USER_ID=tu_email@sellercenter.com
FALABELLA_API_KEY=tu_api_key_de_sellercenter
FALABELLA_SC_API_HOST=https://sellercenter-api.falabella.com
