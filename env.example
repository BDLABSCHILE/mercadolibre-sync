# =============================================================================
# mercadolibre-sync — variables de entorno
# Copia este archivo a .env y reemplaza con tus credenciales.
# =============================================================================

# ----- Runtime --------------------------------------------------------------
NODE_ENV=production          # 'development' habilita logs pretty (pino-pretty)
PORT=3000                    # Render setea su propio PORT
LOG_LEVEL=info               # fatal | error | warn | info | debug | trace

# ----- Base de datos (Postgres / Neon) --------------------------------------
# Connection string de Neon. Pega el que te muestra Neon al crear el proyecto.
# Formato: postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ----- Shopify --------------------------------------------------------------
SHOPIFY_STORE_URL=tu-tienda.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_LOCATION_ID=12345678901

# API Secret de la app Shopify (NO el access token).
# Se usa para verificar HMAC en webhooks. Sin esto los webhooks se aceptan
# sin verificación con un warning en logs.
# Lo encuentras en Apps → Develop apps → tu app → API credentials → API secret key.
SHOPIFY_API_SECRET=

# ----- MercadoLibre ---------------------------------------------------------
MELI_APP_ID=123456789012345
MELI_CLIENT_SECRET=tu_client_secret_de_mercadolibre
MELI_REFRESH_TOKEN=TG-xxxxxxxxxxxxxxxxxxxxxxxx-1234567890
MELI_USER_ID=1234567890
# MELI_ACCESS_TOKEN es opcional: si lo omites, se obtiene automáticamente
# usando MELI_REFRESH_TOKEN al primer request.
# MELI_ACCESS_TOKEN=APP_USR-xxx

# ----- Falabella (Seller Center API) ----------------------------------------
# Activación: en false NO se inicializa el cliente Falabella.
ENABLE_FALABELLA=false

# Chile: https://sellercenter-api.linio.cl
# Perú/Colombia: https://sellercenter-api.falabella.com
FALABELLA_SC_API_HOST=https://sellercenter-api.falabella.com
FALABELLA_USER_ID=tu_email_de_sellercenter
FALABELLA_API_KEY=tu_api_key_de_sellercenter
FALABELLA_API_VERSION=1.0
FALABELLA_API_FORMAT=XML

# Código país para BusinessUnits en ProductUpdate: facl=Chile, fape=Perú, faco=Colombia
FALABELLA_OPERATOR_CODE=facl
FALABELLA_HTTP_TIMEOUT_MS=30000

# ----- Reglas de negocio ----------------------------------------------------
# Stock que se publica en marketplaces = stock_shopify - offset (mínimo 0).
STOCK_OFFSET=1
# Si no se setea, usa STOCK_OFFSET. Permite ajuste fino por marketplace.
# STOCK_OFFSET_FALABELLA=1

# Precio en marketplaces = precio_shopify * markup, redondeado hacia arriba
# al próximo número terminado en PRICE_ROUND_ENDING. Ej: 23.400 → 23.990.
PRICE_MARKUP=1.3
PRICE_ROUND_ENDING=990

# Dir para cache de items ML refrescados (usar dir escribible).
# MELI_CACHE_DIR=/tmp

# ----- Sincronización general (/sync-all) -----------------------------------
# Genera un string secreto largo. Sin esto el endpoint devuelve 403.
# Uso: GET /sync-all?key=TU_SECRETO
SYNC_ALL_SECRET=
# Pausa entre cada SKU en ms (evitar 429 marketplaces). Si ves 429 sube a 2000.
SYNC_ALL_DELAY_MS=1200
# Opcional: filtrar SKUs.
# SYNC_ALL_SKU_LIST=B-G-MOKA,T-M-CRU,B-M-CRU
# SYNC_ALL_SKU_PREFIX=B-G-,T-M-

# ----- Catch-up de órdenes pendientes ---------------------------------------
# Ventana de horas hacia atrás que revisa check-pending-orders al arrancar.
PENDING_ORDERS_LAST_HOURS=24

# ----- Reconciliador de stock (cron) ----------------------------------------
# Frecuencia en minutos del cron del reconciliador. 0 = OFF (solo manual via
# endpoint /admin/reconcile-stock). Sugeridos:
#   1440 = una vez al día (volumen bajo, recomendado para Valiz)
#   240  = cada 4 horas (volumen medio)
#   60   = cada hora (volumen alto)
# El reconciliador detecta drift entre Shopify (fuente de verdad) y los
# marketplaces, y auto-corrige escribiendo max(0, stock_shopify - offset).
RECONCILE_INTERVAL_MIN=0
