# Shopify Configuration
SHOPIFY_STORE_URL=tu-tienda.myshopify.com
SHOPIFY_ACCESS_TOKEN=tu_access_token_aqui
SHOPIFY_LOCATION_ID=tu_location_id_aqui

# MercadoLibre Configuration
MELI_APP_ID=tu_app_id
MELI_CLIENT_SECRET=tu_client_secret
MELI_REFRESH_TOKEN=tu_refresh_token
MELI_USER_ID=tu_user_id
# MELI_ACCESS_TOKEN es opcional - se obtiene automáticamente usando MELI_REFRESH_TOKEN
# MELI_ACCESS_TOKEN=tu_access_token

# Sync Configuration
STOCK_OFFSET=1
# El stock en MercadoLibre será: stock_shopify - STOCK_OFFSET (mínimo 0)

# Falabella Seller Center API Configuration
# Docs: https://developers.falabella.com/reference/signing-requests
FALABELLA_SC_API_HOST=https://sellercenter-api.falabella.com
FALABELLA_USER_ID=tu_email_de_sellercenter
FALABELLA_API_KEY=tu_api_key_de_sellercenter
FALABELLA_API_VERSION=1.0
FALABELLA_API_FORMAT=XML
FALABELLA_HTTP_TIMEOUT_MS=30000

# Sync Falabella (independiente)
STOCK_OFFSET_FALABELLA=1
# El stock en Falabella será: stock_shopify - STOCK_OFFSET_FALABELLA (mínimo 0)

# Flag de activación Falabella (modo seguro por defecto)
ENABLE_FALABELLA=false

# Idempotencia (opcional)
# IDEMPOTENCY_STORE=file|memory
# IDEMPOTENCY_STORE=file
# IDEMPOTENCY_FILE_PATH=/tmp
